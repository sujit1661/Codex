<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CodeX TodoList</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/@studio-freight/lenis@1.0.26/bundled/lenis.min.js"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    :root {
      --primary: #e6edf3;
      --success: #2ea043;
      --bg-dark: #000000;
      --bg-secondary: #121212;
      --border-color: #2a2a2a;
      --hover: #1b1b1b;
    }

        html {
      scroll-behavior: auto;
      will-change: transform;
      transform: translateZ(0);
    }


    html, body {
      height: 100%;
      margin: 0;
      padding: 0;
      overflow-x: hidden; /* ✅ force block horizontal overflow */
      width: 100vw;
      background-color: var(--bg-dark);
      color: var(--primary);
       overscroll-behavior-y: contain;

      font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
    }

    .navbar {
      background-color: var(--bg-secondary);
      border-bottom: 1px solid var(--border-color);
    }

    .navbar-brand {
      color: var(--primary);
      font-weight: bold;
      font-size: 1.4rem;
    }

    .layout {
      display: flex;
      min-height: calc(100vh - 60px);
    }

    .sidebar {
      width: 220px;
      background-color: var(--bg-secondary);
      border-right: 1px solid var(--border-color);
      padding-top: 25px;
    }

    .sidebar h5 {
      padding: 10px 20px;
      color: var(--primary);
      border-bottom: 1px solid var(--border-color);
      margin-bottom: 0;
    }

    .sidebar ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .sidebar ul li a {
      display: block;
      padding: 12px 20px;
      color: var(--primary);
      text-decoration: none;
      transition: background 0.2s ease;
    }

    .sidebar ul li a:hover,
    .sidebar ul li a.active {
      background-color: var(--hover);
      color: white;
    }

    .main-content {
      flex-grow: 1;
      padding: 30px;
    }

    .box {
      max-width: 800px;
      margin: 0 auto;
      background-color: var(--bg-secondary);
      border: 1px solid var(--border-color);
      border-radius: 10px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.5);
      margin-bottom: 30px;
      overflow: hidden;
    }

    #heading {
      background-color: var(--hover);
      text-align: center;
    }

    h1 {
      padding: 20px;
      margin: 0;
      color: var(--primary);
      font-size: 1.8rem;
    }

    .item {
      display: flex;
      align-items: center;
      padding: 12px 16px;
      border-bottom: 1px solid var(--border-color);
      transition: background 0.2s ease;
    }

    .item:hover {
      background-color: #222;
    }

    .item:last-child {
      border-bottom: none;
    }

    input[type="checkbox"] {
      margin-right: 15px;
      transform: scale(1.2);
      accent-color: var(--success);
    }

    p {
      flex: 1;
      margin: 0;
      font-size: 17px;
      color: var(--primary);
      word-break: break-word;
    }

    form.edit {
      display: flex;
      flex: 1;
    }

    input[type="text"] {
      background: transparent;
      border: none;
      border-bottom: 1px solid var(--primary);
      color: var(--primary);
      font-size: 17px;
      flex: 1;
      padding: 4px;
    }

    input[type="text"]:focus {
      outline: none;
      box-shadow: 0 1px 0 0 var(--primary);
    }

    ::placeholder {
      color: #666;
      opacity: 1;
    }

    button.add {
      min-height: 50px;
      width: 50px;
      border-radius: 50%;
      border: none;
      background-color: var(--success);
      color: white;
      font-size: 30px;
      transition: background 0.2s ease;
    }

    button.add:hover {
      background-color: #238636;
    }

    button.edit {
      background: none;
      border: none;
      margin-left: 10px;
    }

    .icon {
      height: 20px;
      filter: invert(100%);
      cursor: pointer;
    }

    footer {
      text-align: center;
      padding: 20px;
      color: #666;
      background-color: var(--bg-secondary);
      border-top: 1px solid var(--border-color);
      font-size: 14px;
    }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark px-4">
    <a class="navbar-brand" href="/">CodeX</a>
  </nav>

  <div class="layout">
    <aside class="sidebar">
      <h5>Navigation</h5>
      <ul>
         <li><a href="/" class="active">🏠 Home</a></li>
        <li><a href="/start-dsa">📘 DSA Roadmap</a></li>
        <li><a href="/quizzes">📚 Quizzes</a></li>
        <li><a href="/problems">💡 Problems</a></li>
      </ul>
    </aside>

    <main class="main-content">
      <div class="box" id="heading">
        <h1><%= listTitle %></h1>
      </div>

      <div class="box">
        <% for(let item of listItems){ %>
          <div class="item">
            <form action="/todo/delete" method="post">
              <input type="checkbox" onchange="this.form.submit()" name="deleteItemId" value="<%= item.id %>">
            </form>

            <p id="title<%=item.id%>"><%= item.title %></p>

            <form class="edit" action="/todo/edit" method="post">
              <input type="hidden" name="updatedItemId" value="<%= item.id %>">
              <input id="input<%=item.id%>" type="text" name="updatedItemTitle" value="<%= item.title %>" hidden />
             <button id="done<%=item.id%>" class="edit" type="submit" hidden title="Save">✅</button>
            </form>

            <button id="edit<%=item.id%>" class="edit" onclick="handler('<%=item.id%>')" title="Edit">✏️</button>

          </div>
        <% } %>

        <form class="item" action="/todo/add" method="post">
          <input type="text" name="newItem" placeholder="Add a new task..." autocomplete="off" />
          <!-- Add symbol -->
        <button class="add" type="submit" title="Add Task">+</button>

        </form>
      </div>
    </main>
  </div>

  <footer>
    Copyright © <%= new Date().getFullYear() %> CodeX. All rights reserved.
  </footer>

  <script>

    function handler(id) {
      document.getElementById("title" + id).hidden = true;
      document.getElementById("edit" + id).hidden = true;
      document.getElementById("done" + id).hidden = false;
      document.getElementById("input" + id).hidden = false;
    }
  </script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
