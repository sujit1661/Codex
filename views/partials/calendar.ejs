<div id="calendar" class="bg-dark text-light p-3 rounded" style="max-width: 320px; font-family: 'Segoe UI', sans-serif; font-size: 14px;">
  <div class="d-flex justify-content-between align-items-center mb-2">
    <div>
      <span id="dayLabel">Day</span>
      <span id="dayNumber" class="fw-bold"></span>
      <div id="timeLeft" class="small text-muted"></div>
    </div>
    <div class="d-flex align-items-center">
      <button onclick="changeMonth(-1)" class="btn btn-sm btn-outline-light px-2 py-0">‹</button>
      <span id="monthYear" class="mx-2"></span>
      <button onclick="changeMonth(1)" class="btn btn-sm btn-outline-light px-2 py-0">›</button>
    </div>
  </div>
  <div class="d-flex justify-content-between fw-semibold border-bottom pb-1 mb-2 text-muted">
    <div>S</div><div>M</div><div>T</div><div>W</div><div>T</div><div>F</div><div>S</div>
  </div>
  <div id="calendarGrid" class="d-flex flex-wrap" style="gap: 6px;"></div>
</div>

<script>
  const calendarGrid = document.getElementById("calendarGrid");
  const dayNumber = document.getElementById("dayNumber");
  const monthYear = document.getElementById("monthYear");
  const timeLeft = document.getElementById("timeLeft");

  let currentDate = new Date();

  function updateCalendar() {
    const year = currentDate.getFullYear();
    const month = currentDate.getMonth();
    const today = new Date();

    monthYear.textContent = currentDate.toLocaleString('default', { month: 'short', year: 'numeric' });

    const startOfMonth = new Date(year, month, 1);
    const endOfMonth = new Date(year, month + 1, 0);
    const startDay = startOfMonth.getDay();

    dayNumber.textContent = today.getDate();

    calendarGrid.innerHTML = "";

    for (let i = 0; i < startDay; i++) {
      const blank = document.createElement("div");
      blank.style.width = "36px";
      blank.style.height = "36px";
      calendarGrid.appendChild(blank);
    }

    for (let day = 1; day <= endOfMonth.getDate(); day++) {
      const cell = document.createElement("div");
      cell.textContent = day;
      cell.classList.add("d-flex", "justify-content-center", "align-items-center");
      cell.style.width = "36px";
      cell.style.height = "36px";
      cell.style.borderRadius = "8px";
      cell.style.fontWeight = "500";

      const isToday = today.getDate() === day && today.getMonth() === month && today.getFullYear() === year;

      cell.style.background = isToday ? "#00cc88" : "#2a2a2a";
      cell.style.color = isToday ? "#000" : "#aaa";

      calendarGrid.appendChild(cell);
    }

    updateTimeLeft();
  }

  function changeMonth(delta) {
    currentDate.setMonth(currentDate.getMonth() + delta);
    updateCalendar();
  }

  function updateTimeLeft() {
    const now = new Date();
    const midnight = new Date(now);
    midnight.setHours(24, 0, 0, 0);
    const diff = midnight - now;

    const hours = String(Math.floor(diff / (1000 * 60 * 60))).padStart(2, '0');
    const mins = String(Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60))).padStart(2, '0');
    const secs = String(Math.floor((diff % (1000 * 60)) / 1000)).padStart(2, '0');

    timeLeft.textContent = `${hours}:${mins}:${secs} left`;
    setTimeout(updateTimeLeft, 1000);
  }

  updateCalendar();
</script>
