<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>CodeX - Problems</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">


  <style>
    :root {
      --bg-main: #1e1e1e;
      --bg-dark: #151515;
      --border-gray: #2d2d2d;
      --text-muted: #888;
      --easy: #27ae60;
      --medium: #f1c40f;
      --hard: #e74c3c;
    }


    body {
      background-color: var(--bg-main);
      color: #f0f0f0;
      font-family: 'Segoe UI', sans-serif;
      overflow-x: hidden;
    }

    .navbar {
      background-color: #111;
      padding: 0.8rem 1.5rem;
      border-bottom: 1px solid var(--border-gray);
    }

    .navbar-brand {
      color: #fff;
      font-weight: bold;
    }

    .navbar-brand:hover {
      color: #ddd;
    }

    .sidebar {
      background-color: var(--bg-dark);
      min-height: 100vh;
      padding: 1rem;
      border-right: 1px solid var(--border-gray);
    }

    .sidebar a {
      color: #ccc;
      text-decoration: none;
      display: block;
      padding: 0.5rem 0;
      font-size: 0.95rem;
    }

    .sidebar a:hover {
      color: #fff;
    }

    .sidebar h6 {
      color: #bbb;
      font-size: 0.85rem;
      margin-top: 1.5rem;
    }

    .tag-pill {
      background-color: #2c2c2e;
      color: #ccc;
      padding: 6px 14px;
      border-radius: 30px;
      margin: 6px 6px 6px 0;
      font-size: 0.8rem;
      display: inline-block;
    }

    .problem-card {
      background-color: #2b2b2b;
      border: 1px solid var(--border-gray);
      padding: 1rem;
      border-radius: 10px;
      margin-bottom: 1rem;
      box-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);
    }

    .problem-card:hover {
      background-color: #333;
      cursor: pointer;
    }

    .difficulty {
      padding: 4px 12px;
      border-radius: 12px;
      font-size: 0.75rem;
      font-weight: bold;
    }

    .easy {
      background-color: var(--easy);
      color: white;
    }

    .medium {
      background-color: var(--medium);
      color: black;
    }

    .hard {
      background-color: var(--hard);
      color: white;
    }

    .right-panel {
      background-color: #121212;
      border: 1px solid var(--border-gray);
      border-radius: 10px;
      padding: 1rem;
      margin-bottom: 1rem;
    }

    .form-control {
      background-color: #1f1f1f;
      border: 1px solid #444;
      color: #ccc;
    }

    .form-control::placeholder {
      color: #888;
    }

    .search-bar {
      margin: 10px 0 20px;
    }

    .tag-scroll {
      white-space: nowrap;
      overflow-x: auto;
      scrollbar-width: none;
    }

    .tag-scroll::-webkit-scrollbar {
      display: none;
    }
  </style>
</head>
<body>
     <!--navbar-->
    <nav class="navbar navbar-dark justify-content-between">
      <a class="navbar-brand" href="#">CodeX</a>

      <div class="d-flex align-items-center">
        <!-- Notes Icon -->
        <a href="/notes" class="btn btn-dark me-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;" title="DSA Notes">
          <i class="bi bi-filetype-pdf text-light fs-5"></i>
        </a>


        <!-- Profile Dropdown -->
        <div class="dropdown">
          <a href="#" class="d-flex align-items-center text-white text-decoration-none dropdown-toggle" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
            <img src="<%= user.profile_image || 'https://upload.wikimedia.org/wikipedia/commons/e/ea/Dog_coat_variation.png' %>" alt="Profile" width="32" height="32" class="rounded-circle me-2">
            <strong><%= user.name %></strong>
          </a>
          <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark text-small shadow" aria-labelledby="userDropdown">
            <li><a class="dropdown-item" href="/profile">My Profile</a></li>
            <li><a class="dropdown-item" href="/settings">Settings</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="/logout">Sign out</a></li>
          </ul>
        </div>
      </div>
    </nav>



  <div class="container-fluid">
    <div class="row">

      <!-- Sidebar -->
      <div class="col-md-2 sidebar">
        <a href="/">🏠 Home</a>
        <a href="/problems">🧠 Problems</a>
        <a href="#">📚 Library</a>
        <a href="/study_plan">📝 Study Plan</a>
        <h6>My Lists</h6>
        <a href="#">⭐ Favorite</a>
        <a href="#">📄 Counting Sort</a>
      </div>

      <!-- Main Content + Right Panel -->
      <div class="col-md-10 d-flex flex-wrap">

        <!-- Main Content -->
        <div class="col-md-9 py-4 px-4">
          <!-- Tag Bar -->
          <div class="tag-scroll mb-3">
            <span class="tag-pill">Array 1944</span>
            <span class="tag-pill">String 798</span>
            <span class="tag-pill">DP 600</span>
            <span class="tag-pill">Graph 167</span>
            <span class="tag-pill">Greedy 421</span>
            <span class="tag-pill">Sorting 457</span>
          </div>

          <!-- Search and Filters -->
          <div class="d-flex align-items-center search-bar">
            <button class="btn btn-outline-light btn-sm me-2">All Topics</button>
            <button class="btn btn-outline-light btn-sm me-2">Algorithms</button>
            <button class="btn btn-outline-light btn-sm me-2">Shell</button>
            <input id="searchInput" type="text" class="form-control form-control-sm ms-auto w-50" placeholder="Search problems...">
          </div>

          <!-- Problem Cards -->
          <div id="problemsList">
          <% problems1.forEach(problem => { %>
            <a href="/problems/<%= problem.id %>" class="problem-link" style="text-decoration: none; color: inherit;">
              <div class="problem-card d-flex justify-content-between align-items-center">
                <div class="problem-title"><strong><%= problem.number %></strong> <%= problem.title %></div>
                <div>
                  <span class="difficulty <%= problem.difficulty.toLowerCase() %>">
                    <%= problem.difficulty %>
                  </span>
                </div>
              </div>
            </a>
          <% }); %>
        </div>
        </div>

        <!-- Right Sidebar -->
        <div class="col-md-3 py-4 px-3 d-flex flex-column align-items-stretch">
          <!-- Activity Calendar -->
         <%- include('partials/calendar') %>
         <br>


          <!-- Trending Companies -->
          <div class="right-panel">
            <h6 class="mb-3">🚀 Trending Companies</h6>
            <div class="d-flex flex-wrap gap-2">
              <span class="badge bg-light text-dark">Google</span>
              <span class="badge bg-warning text-dark">Amazon</span>
              <span class="badge bg-info text-dark">Meta</span>
            </div>
          </div>
        </div>

      </div> <!-- /.col-md-10 -->

    </div> <!-- /.row -->
  </div> <!-- /.container-fluid -->

<!--  used for search to search question-->
    <script>
      const searchInput = document.getElementById('searchInput');
      const problemLinks = document.querySelectorAll('#problemsList .problem-link');
      searchInput.addEventListener('input', () => {
        const term = searchInput.value.toLowerCase();

        problemLinks.forEach(link => {
          const text = link.querySelector('.problem-title').textContent.toLowerCase();
          link.style.display = text.includes(term) ? 'block' : 'none';
        });
      });
</script>


  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>


</body>
</html>
