<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title><%= problem.title %> | CodeX</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/@studio-freight/lenis@1.0.26/bundled/lenis.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/monaco-editor@0.45.0/min/vs/loader.js"></script>

  <style>
    html, body {
      margin: 0; padding: 0; height: 100%;
      background-color: #0d1117; color: #c9d1d9;
      font-family: 'Segoe UI', sans-serif;
      overflow: hidden;
    }

    .container-fluid { display: flex; height: 100vh; }

    #leftPanel {
      width: 40%; background-color: #161b22;
      overflow-y: auto; padding: 20px;
      border-right: 1px solid #30363d;
    }

    #dragBar {
      width: 6px; cursor: col-resize;
      background-color: #30363d;
    }

    #rightPanel {
      flex: 1; display: flex; flex-direction: column; overflow: hidden;
    }

    .editor-header {
      display: flex; align-items: center; justify-content: space-between;
      background-color: #161b22; padding: 10px 20px;
      border-bottom: 1px solid #30363d;
    }

    .editor-header .form-select { max-width: 150px; }

    #codeArea {
      flex: 1;
      min-height: 300px;
    }

    .resizable-section {
      background-color: #0d1117;
      border-top: 1px solid #30363d;
      padding: 10px 20px;
      overflow: auto;
    }

    textarea.form-control {
      background-color: #161b22;
      color: #c9d1d9;
      border: 1px solid #444;
    }

    #outputBox {
      height: 100%;
      width: 100%;
      background-color: #161b22;
      color: #e6e6e6;
      border: 1px solid #444;
      border-radius: 6px;
      padding: 10px;
      font-family: Consolas, monospace;
      font-size: 14px;
      white-space: pre-wrap;
      overflow-y: auto;
      box-sizing: border-box;
    }

    .badge.difficulty {
      font-size: 0.75rem;
      padding: 5px 10px;
      border-radius: 12px;
    }

    .easy { background-color: #2ea043; }
    .medium { background-color: #facc15; color: #000; }
    .hard { background-color: #f43f5e; }

    #runBtn:hover {
      background-color: #198754;
      box-shadow: 0 0 10px rgba(40, 167, 69, 0.8);
    }

    #outputSection {
      height: 200px;
      resize: vertical;
    }

    #dragOutputBar {
      height: 6px;
      cursor: row-resize;
      background-color: #30363d;
    }
  </style>
</head>
<body>
     <nav class="navbar navbar-dark bg-dark px-4 d-flex justify-content-between align-items-center">
      <a href="/problems" class="btn btn-outline-light btn-sm">Back to Problems</a>

      <!-- Add this div to align assistant button to top-right -->
      <div class="ms-auto d-flex align-items-center">
        <%- include('partials/codex-ai-panel') %>
      </div>
    </nav>




  <div class="container-fluid">
    <!-- Left Panel -->
    <div id="leftPanel">
      <h4><%= problem.title %></h4>
      <span class="badge difficulty <%= problem.difficulty.toLowerCase() %>"><%= problem.difficulty %></span>
      <hr />

      <h5>Description</h5>
      <p><%= problem.description || 'No description available.' %></p>



      <h6 class="mt-4">🔢 Example Input</h6>
      <pre><code><%= problem.input_format || 'N/A' %></code></pre>

      <h6>✅ Example Output</h6>
      <pre><code><%= problem.output_format || 'N/A' %></code></pre>

        <% if (problem.hint) { %>
          <div class="mt-5 p-3 border-start border-3 border-warning bg-dark rounded shadow-sm">
            <h6 class="text-warning mb-2">💡 Hint</h6>
            <p class="mb-0"><%= problem.hint %></p>
          </div>
        <% } %>

    </div>


    <!-- Drag Bar -->
    <div id="dragBar"></div>

    <!-- Right Panel -->
    <div id="rightPanel">
      <div class="editor-header">
        <h5>Code Editor</h5>
        <div class="d-flex gap-2">
          <select id="language" class="form-select form-select-sm bg-dark text-light border-secondary">
            <option value="python">Python</option>
            <option value="java">Java</option>
            <option value="cpp">C++</option>
            <option value="c">C</option>
            <option value="javascript">JavaScript</option>
            <option value="go">Go</option>
            <option value="typescript">TypeScript</option>
            <option value="ruby">Ruby</option>
            <option value="bash">Bash</option>
            <option value="rust">Rust</option>
          </select>
          <button id="runBtn" class="btn btn-success btn-sm">Run</button>
        </div>
      </div>

      <!-- Monaco Code Editor -->
      <div id="codeArea"></div>

      <!-- Custom Input -->
      <div class="resizable-section">
        <label>Custom Input (stdin)</label>
        <textarea id="stdinInput" class="form-control" rows="4" placeholder="e.g. 5\n10"></textarea>
      </div>

      <!-- Drag Output Bar -->
      <div id="dragOutputBar"></div>

      <!-- Output -->
      <div id="outputSection" class="resizable-section">
        <label>Output</label>
        <pre id="outputBox">Output will appear here...</pre>
      </div>
    </div>
  </div>


  <script>
    const defaultCodes = <%- JSON.stringify(defaultCode || {}) %>;
    const langMap = {
      python: 71, java: 62, cpp: 54, c: 50, javascript: 63,
      typescript: 74, ruby: 72, bash: 46, go: 60, rust: 73
    };

    const languageDropdown = document.getElementById('language');
    const outputBox = document.getElementById('outputBox');
    let editor;

    require.config({ paths: { vs: 'https://cdn.jsdelivr.net/npm/monaco-editor@0.45.0/min/vs' }});
    require(['vs/editor/editor.main'], function () {
      editor = monaco.editor.create(document.getElementById('codeArea'), {
        value: (defaultCodes[languageDropdown.value] || '// Code not available').replace(/\\n/g, '\n'),
        language: languageDropdown.value,
        theme: 'vs-dark',
        tabSize: 4,
        insertSpaces: true,
        automaticLayout: true
      });

      languageDropdown.addEventListener('change', () => {
        const lang = languageDropdown.value;
        const newCode = defaultCodes[lang] || '// Code not available';
        editor.setValue(newCode.replace(/\\n/g, '\n'));
        const langAliasMap = {
          python: 'python',
          java: 'java',
          cpp: 'cpp',
          c: 'c',
          javascript: 'javascript',
          typescript: 'typescript',
          ruby: 'ruby',
          bash: 'shell',
          go: 'go',
          rust: 'rust'
        };

        monaco.editor.setModelLanguage(editor.getModel(), langAliasMap[lang] || 'plaintext');

      });
    });

    document.getElementById('runBtn').addEventListener('click', async () => {
      const lang = languageDropdown.value;
      const code = editor.getValue();
      const stdin = document.getElementById('stdinInput').value;
      outputBox.textContent = '⏳ Running...';

      try {
        const res = await fetch('/run', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ source_code: code, language_id: langMap[lang], stdin })
        });

        const result = await res.json();
        outputBox.textContent = result.stderr
          ? "❌ Error:\n" + result.stderr
          : "✅ Output:\n" + result.stdout;
      } catch (err) {
        outputBox.textContent = `⚠️ Failed to run code:\n${err.message}`;
      }
    });

    // Resize left panel
    const leftPanel = document.getElementById('leftPanel');
    const dragBar = document.getElementById('dragBar');
    let isDragging = false;
    dragBar.addEventListener('mousedown', e => {
      e.preventDefault();
      isDragging = true;
      document.body.style.cursor = 'col-resize';
    });
    document.addEventListener('mousemove', e => {
      if (!isDragging) return;
      const minWidth = 250;
      const maxWidth = window.innerWidth - 400;
      const newWidth = Math.min(Math.max(e.clientX, minWidth), maxWidth);
      leftPanel.style.width = newWidth + 'px';
    });
    document.addEventListener('mouseup', () => {
      isDragging = false;
      document.body.style.cursor = 'default';
    });

    // Resize output panel
    const dragOutputBar = document.getElementById('dragOutputBar');
    const outputSection = document.getElementById('outputSection');
    let isResizingOutput = false;
    dragOutputBar.addEventListener('mousedown', e => {
      e.preventDefault();
      isResizingOutput = true;
      document.body.style.cursor = 'row-resize';
    });
    document.addEventListener('mousemove', e => {
      if (!isResizingOutput) return;
      const minHeight = 120;
      const maxHeight = 500;
      const newHeight = Math.min(Math.max(window.innerHeight - e.clientY, minHeight), maxHeight);
      outputSection.style.height = newHeight + 'px';
    });
    document.addEventListener('mouseup', () => {
      isResizingOutput = false;
      document.body.style.cursor = 'default';
    });

    // Smooth scroll
    const lenis = new Lenis({
      duration: 1.2,
      easing: t => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      smooth: true
    });
    function raf(time) {
      lenis.raf(time);
      requestAnimationFrame(raf);
    }
    requestAnimationFrame(raf);
  </script>
</body>
</html>
