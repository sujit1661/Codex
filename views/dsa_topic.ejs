 <!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= data.title %> | CodeX</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">


  <style>

        html, body {
      height: auto;          /* Allow full content height */
      overflow-x: hidden;
      scroll-behavior: auto; /* Prevent conflict with Lenis */
    }


    body {
      font-family: 'Inter', sans-serif;
      background-color: #f4f4f4;
      color: #000;
      transition: background-color 0.3s ease, color 0.3s ease;
    }
    body.dark-mode {
      background-color: #121212;
      color: #e0e0e0;
    }
    .dark-mode .section-card {
      background-color: #1f1f1f;
      border-color: #444;
    }
    .dark-mode .sidebar {
      background-color: #1c1c1c;
      border-color: #444;
    }
    .dark-mode .sidebar a {
      background-color: #292929;
      color: #e0e0e0;
      border-color: #444;
    }
    .dark-mode .sidebar a:hover,
    .dark-mode .sidebar a.active {
      background-color: #374151;
      color: #90cdf4;
    }
    .sidebar {
      position: fixed;
      top: 0;
      left: 0;
      height: 100vh;
      width: 240px;
      background-color: #fff;
      border-right: 1px solid #ddd;
      padding-top: 70px;
      overflow-y: auto;
      padding-left: 10px;
      padding-right: 10px;
    }
    .sidebar a {
      display: block;
      padding: 12px 20px;
      color: #333;
      text-decoration: none;
      font-weight: 600;
      border: 1px solid #e0e0e0;
      border-radius: 6px;
      margin-bottom: 10px;
      background-color: #fdfdfd;
    }
    .sidebar a:hover,
    .sidebar a.active {
      background-color: #e6f0ff;
      color: #007bff;
    }
    .main-content {
      margin-left: 260px;
      padding: 2rem;
    }
    .section-card {
      background-color: #fff;
      border: 2px solid #ccc;
      border-radius: 10px;
      padding: 2rem;
      margin-bottom: 2.5rem;
    }
    .section-card h4,
    .section-card h2 {
      font-weight: 700;
      margin-bottom: 1.2rem;
      color: inherit;
    }
    .section-card h2.display-5 {
      font-size: 2.5rem;
      color: #0056b3;
    }
    .section-card p,
    .section-card li,
    .section-card label {
      font-size: 1rem;
      line-height: 1.7;
    }
    .section-card strong {
      font-weight: 600;
    }
    .code-block {
      background-color: #1e1e2f;
      color: #9effff;
      padding: 1rem;
      border-radius: 10px;
      font-family: monospace;
      overflow-x: auto;
      white-space: pre-wrap;
    }
    .output-box {
      background-color: #f8f9fa;
      padding: 1rem;
      border-radius: 6px;
      border: 1px solid #ccc;
      font-family: monospace;
      white-space: pre-wrap;
    }
    .section-card ul li {
      background: #f9f9f9;
      padding: 0.75rem 1rem;
      margin-bottom: 0.5rem;
      border-radius: 6px;
      font-weight: 500;
    }
    ol li {
      margin-bottom: 0.75rem;
      font-weight: 500;
    }
    .theme-toggle {
      cursor: pointer;
      border: none;
      background: transparent;
      color: #fff;
      font-size: 1.3rem;
      margin-left: 1rem;
    }

    /* Fix for table */
        .dark-mode table {
          background-color: #1f1f1f;
          color: #e0e0e0;
        }
        .dark-mode table thead {
          background-color: #292929;
        }
        .dark-mode table th,
        .dark-mode table td {
          border-color: #444;
        }

        /* Fix for code block text area, inputs, selects */
        .dark-mode .form-control,
        .dark-mode .form-select {
          background-color: #1c1c1c;
          color: #e0e0e0;
          border-color: #555;
        }

        /* Fix for output box */
        .dark-mode .output-box {
          background-color: #2b2b2b;
          color: #90ee90;
          border-color: #555;
        }

        /* Fix for pre/code blocks */
        .dark-mode .code-block {
          background-color: #272c36;
          color: #00ffff;
        }

        .scroll-fade {
        opacity: 0;
        transform: translateY(40px);
        transition: opacity 0.8s ease, transform 0.8s ease;
      }

        .scroll-fade.visible {
          opacity: 1;
          transform: translateY(0);
        }


  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top px-4">
    <a class="navbar-brand fw-bold text-info" href="/">CodeX DSA</a>
    <div class="ms-auto d-flex align-items-center">
      <a href="/start-dsa" class="btn btn-outline-info">← Back to Roadmap</a>
<button class="theme-toggle" id="themeToggle" title="Toggle Theme">
  <i class="fas fa-moon"></i>
</button>    </div>
  </nav>

    <div class="sidebar"> -->
    <a href="#intro">Introduction</a>
    <% if (data.bullet_heading) { %><a href="#concepts"><%= data.bullet_heading %></a><% } %>
    <% if (data.code_heading_1) { %><a href="#code1"><%= data.code_heading_1 %></a><% } %>
    <% if (data.code_heading_2) { %><a href="#code2"><%= data.code_heading_2 %></a><% } %>
    <% if (data.table_heading) { %><a href="#complexity">Time Complexities</a><% } %>
    <% if (data.analogy_heading) { %><a href="#analogy">Analogy</a><% } %>
    <% if (data.video_heading) { %><a href="#video">Video</a><% } %>
    <% if (data.compiler_heading) { %><a href="#compiler">Try It</a><% } %>
  </div>

  <div class="main-content">
    <div class="section-card" id="intro">
      <h2 class="display-5 fw-bold"><%= data.title %></h2>
      <% if (data.subtitle) { %><p class="text-muted fw-semibold"><%= data.subtitle %></p><% } %>
      <% if (data.description) { %>
        <p><%- data.description.replace(/\n/g, '<br>') %></p>
      <% } %>
    </div>

    <% if (data.bullet_heading && data.bullets && data.bullets.length > 0) { %>
      <div class="section-card" id="concepts">
        <h4><%= data.bullet_heading %></h4>
        <ol>
          <% data.bullets.forEach((b, i) => { %>
            <li><%= b %></li>
          <% }) %>
        </ol>
      </div>
    <% } %>

    <% if (data.code_heading_1 && data.code_snippet_1) { %>
      <div class="section-card" id="code1">
        <h4><%= data.code_heading_1 %></h4>
        <div class="code-block"><%= data.code_snippet_1 %></div>
      </div>
    <% } %>

    <% if (data.code_heading_2 && data.code_snippet_2) { %>
      <div class="section-card" id="code2">
        <h4><%= data.code_heading_2 %></h4>
        <div class="code-block"><%= data.code_snippet_2 %></div>
      </div>
    <% } %>

    <% if (data.table_heading) { %>
      <div class="section-card" id="complexity">
        <h4>Time Complexities</h4>
        <table class="table table-bordered">
          <thead class="table-light">
            <tr><th>Algorithm</th><th>Time</th><th>Space</th></tr>
          </thead>
          <tbody><%- data.table_heading %></tbody>
        </table>
      </div>
    <% } %>

    <% if (data.analogy_heading && data.analogy_description) { %>
      <div class="section-card" id="analogy">
        <h4><%= data.analogy_heading %></h4>
        <p><strong><%= data.analogy_description %></strong></p>
      </div>
    <% } %>

    <% if (data.video_heading && data.video_url) { %>
      <div class="section-card" id="video">
        <h4><%= data.video_heading %></h4>
        <div class="ratio ratio-16x9">
          <iframe src="<%= data.video_url %>" allowfullscreen></iframe>
        </div>
      </div>
    <% } %>

    <% if (data.compiler_heading && data.compiler_url) { %>
      <div class="section-card" id="compiler">
        <h4><%= data.compiler_heading %></h4>
        <select id="language" class="form-select w-auto mb-2">
          <option value="python">Python</option>
          <option value="cpp">C++</option>
          <option value="java">Java</option>
        </select>
        <textarea id="codeArea" class="form-control mb-2" rows="8">print("Hello, CodeX!")</textarea>
        <textarea id="stdinInput" class="form-control mb-2" placeholder="Custom Input"></textarea>
        <button class="btn btn-primary mb-2" id="runBtn">▶️ Run</button>
        <div class="output-box" id="outputBox">Output will appear here...</div>
      </div>
    <% } %>

    <div class="text-center mb-4">
      <button id="completeBtn" class="btn btn-outline-success">✅ Mark as Completed</button>
      <p id="completeStatus" class="text-success mt-2" style="display:none">🎉 Completed!</p>
    </div>
  </div>
  <script>
    document.getElementById('runBtn')?.addEventListener('click', async () => {
      const lang = document.getElementById('language').value;
      const code = document.getElementById('codeArea').value;
      const stdin = document.getElementById('stdinInput').value;
      const outputBox = document.getElementById('outputBox');

      outputBox.textContent = '⏳ Running...';

      try {
        const res = await fetch(`https://apiforcode.dailywith.me/api/v1/compile/${lang}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ source: code, stdin: stdin })
        });
        const data = await res.json();

        if (data.stderr?.length) {
          outputBox.textContent = "❌ Error:\n" + data.stderr.map(e => e.text).join('\n');
        } else {
          outputBox.textContent = "✅ Output:\n" + data.stdout.map(e => e.text).join('');
        }
      } catch (err) {
        outputBox.textContent = `⚠️ Failed to run code:\n${err.message}`;
      }
    });

    const slug = "<%= data.topic_slug %>";
    const btn = document.getElementById('completeBtn');
    const status = document.getElementById('completeStatus');
    if (localStorage.getItem(`completed_${slug}`)) {
      btn.disabled = true;
      btn.innerText = "✅ Completed";
      status.style.display = "block";
    }
    btn.addEventListener('click', () => {
      localStorage.setItem(`completed_${slug}`, 'true');
      btn.disabled = true;
      btn.innerText = "✅ Completed";
      status.style.display = "block";
    });


    document.getElementById('themeToggle').addEventListener('click', () => {
      document.body.classList.toggle('dark-mode');
    });




  const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
    }
  });
}, { threshold: 0.2 });

document.querySelectorAll('.scroll-fade').forEach(el => {
  observer.observe(el);
});

</script>
</body>
</html>
