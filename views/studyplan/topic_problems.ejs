<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= topic %> | Study Plan</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body {
      background: #0f0f0f;
      color: #fff;
      font-family: 'Segoe UI', sans-serif;
    }

    .navbar {
      background-color: #121212;
      border-bottom: 1px solid #333;
    }

    .navbar-brand {
      font-weight: bold;
      color: #00bfff !important;
    }

    .sidebar {
      background-color: #151515;
      padding: 1.2rem;
      min-height: 100vh;
      border-right: 1px solid #333;
      width: 230px;
    }

    .sidebar h5 {
      font-size: 1.1rem;
      color: #ccc;
      margin-bottom: 1rem;
    }

    .sidebar a {
      display: block;
      color: #aaa;
      text-decoration: none;
      margin-bottom: 0.6rem;
      font-size: 0.95rem;
    }

    .sidebar a:hover {
      color: #fff;
    }

    .progress-container {
      padding: 2rem;
    }

    .section-header {
      margin-bottom: 2rem;
      background: #1b1b1b;
      padding: 1.5rem;
      border-radius: 12px;
      border: 1px solid #333;
    }

    .section-header h2 {
      margin-bottom: 0.5rem;
    }

    .section-header p {
      color: #aaa;
      font-size: 0.95rem;
    }

    .problem-card {
      background: #1b1b1b;
      border: 1px solid #333;
      padding: 1rem;
      margin-bottom: 1rem;
      border-radius: 10px;
      transition: background 0.3s ease;
    }

    .problem-card:hover {
      background: #2b2b2b;
    }

    .difficulty {
      padding: 4px 12px;
      border-radius: 12px;
      font-size: 0.75rem;
      font-weight: bold;
    }

    .easy { background-color: #2ecc71; }
    .medium { background-color: #f1c40f; color: #000; }
    .hard { background-color: #e74c3c; }

    .done {
      text-decoration: line-through;
      color: #aaa;
    }
  </style>
</head>
<body>

  <!-- Navbar -->
  <nav class="navbar navbar-dark px-4 py-2 d-flex justify-content-between align-items-center">
    <a class="navbar-brand" href="/">← CodeX</a>
    <div class="d-flex gap-3">
      <a class="text-light text-decoration-none" href="/"><strong>Home</strong></a>
      <a class="text-light text-decoration-none" href="/problems"><strong>Problems</strong></a>
    </div>
  </nav>

  <div class="container-fluid">
    <div class="row">

      <!-- Sidebar -->
      <div class="col-md-2 sidebar">
        <h5>📚 Topics</h5>
        <a href="/study/DSA Basics">DSA Basics & Loops</a>
        <a href="/study/Arrays">Arrays</a>
        <a href="/study/Matrix">Matrix</a>
        <a href="/study/Strings">Strings</a>
        <a href="/study/Searching & Sorting">Searching & Sorting</a>
        <a href="/study/Stack & Queue">Stack & Queue</a>
        <a href="/study/Linked List">Linked List</a>
        <a href="/study/Tree">Trees</a>
        <a href="/study/Hashmap & Hashset">Hashmap & Hashset</a>
      </div>

      <!-- Main Content -->
      <div class="col-md-10 progress-container">
        <div class="section-header">
          <h2><%= topic %> - Topic Practice</h2>
          <p>Dive into <%= topic %> problems curated to strengthen your understanding. Track your progress as you solve each one.</p>

          <!-- Progress bar -->
          <label>Progress</label>
          <div class="progress">
            <div class="progress-bar" id="progressBar" role="progressbar" style="width: 0%">0%</div>
          </div>
        </div>

        <!-- Problem list -->
        <% problems.forEach(problem => { %>
          <div class="problem-card d-flex justify-content-between align-items-center">
            <a href="/problems/<%= problem.id %>" class="text-decoration-none fw-semibold text-white problem-link"
               data-id="<%= problem.id %>">
              <span class="problem-title" id="title-<%= problem.id %>">
                <%= problem.number %>. <%= problem.title %>
              </span>
            </a>
            <span class="badge difficulty <%= problem.difficulty.toLowerCase() %>">
              <%= problem.difficulty %>
            </span>
          </div>
        <% }) %>
      </div>
    </div>
  </div>

  <script>
    const problems = <%- JSON.stringify(problems.map(p => p.id)) %>;

    problems.forEach(id => {
      if (localStorage.getItem('done_' + id)) {
        const title = document.getElementById('title-' + id);
        if (title) title.classList.add('done');
      }
    });

    function updateProgress() {
      const done = problems.filter(id => localStorage.getItem('done_' + id));
      const percent = Math.round((done.length / problems.length) * 100);
      const bar = document.getElementById('progressBar');
      bar.style.width = percent + '%';
      bar.textContent = percent + '%';
    }

    document.querySelectorAll('.problem-link').forEach(link => {
      link.addEventListener('click', () => {
        const id = link.getAttribute('data-id');
        localStorage.setItem('done_' + id, 'true');
      });
    });

    updateProgress();
  </script>
</body>
</html>
