<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>CodeX Study Plan</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;800&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/@studio-freight/lenis@1.0.26/bundled/lenis.min.js"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

  <style>
    * {
      box-sizing: border-box;
      font-family: 'Poppins', sans-serif;
    }

    html {
      scroll-behavior: auto; /* Let Lenis handle it */
      will-change: transform;
      transform: translateZ(0);
    }

    body {
      margin: 0;
      background: #131313;
      min-height: 100vh;
      padding: 2rem;
      color: #fff;
      overflow-x: hidden;
    }

    nav {
      width: 100%;
      display: flex;
      justify-content: flex-start;
      margin-bottom: 2rem;
    }

    nav a {
      text-decoration: none;
      color: #00bfff;
      font-weight: 600;
      border: 1px solid #00bfff;
      padding: 8px 16px;
      border-radius: 5px;
      transition: background 0.3s ease;
    }

    nav a:hover {
      background: #00bfff;
      color: #000;
    }

    .container {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 2rem;
    }

    .card {
      position: relative;
      width: 340px;
      height: 480px;
      background: rgba(35, 35, 35, 0.8);
      border-radius: 20px;
      overflow: hidden;
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.4);
      transition: transform 0.5s ease, box-shadow 0.4s ease;
      opacity: 0;
      transform: translateY(40px);
    }

    .card.in-view {
      opacity: 1;
      transform: translateY(0);
      transition: 0.8s ease;
    }

    .card:hover {
      border: 1px solid rgba(80, 195, 255, 0.8);
      box-shadow: 0 0 12px rgba(80, 195, 255, 0.5), 0 10px 20px rgba(0, 0, 0, 0.5);
      transform: scale(1.015);
    }

    .card::before, .card::after {
      content: '';
      position: absolute;
      left: 0;
      width: 100%;
      height: 3px;
      background: #00bfff;
      opacity: 0;
      transition: 0.3s;
    }

    .card::before { top: 0; }
    .card::after { bottom: 0; }

    .card:hover::before,
    .card:hover::after {
      opacity: 1;
    }

    .imgBx {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 1;
      width: 100%;
      height: 200px;
      transition: top 0.5s, transform 0.5s;
    }

    .card:hover .imgBx {
      top: 0%;
      transform: translateY(0%);
    }

    .imgBx img {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 180px;
    }

    .contentBx {
      position: absolute;
      bottom: 0;
      width: 100%;
      height: 120px;
      text-align: center;
      transition: height 1s;
      z-index: 2;
    }

    .card:hover .contentBx {
      height: 240px;
    }

    .contentBx h2 {
      font-weight: 600;
      letter-spacing: 1px;
      color: #fff;
      margin: 0;
    }

    .details {
      opacity: 0;
      visibility: hidden;
      transition: 0.5s;
      color: #e0e0e0;
      font-size: 14px;
      padding: 10px 20px;
    }

    .card:hover .details {
      opacity: 1;
      visibility: visible;
      transition-delay: 0.4s;
    }

    .btn {
      display: inline-block;
      padding: 10px 20px;
      background: #fff;
      border-radius: 4px;
      margin-top: 10px;
      text-decoration: none;
      font-weight: 600;
      color: #111;
      opacity: 0;
      transform: translateY(40px);
      transition: 0.5s;
    }

    .card:hover .btn {
      opacity: 1;
      transform: translateY(0);
      transition-delay: 0.6s;
    }
  </style>
</head>
<body>

<nav>
  <a href="/problems">← Back to Problems</a>
</nav>

<div class="container">
  <% topics.forEach(topic => { %>
    <div class="card">
      <div class="imgBx">
        <img src="/images/<%= topic.topic.replace(/ /g, '_').toLowerCase() %>.svg" alt="<%= topic.topic %> Icon">
      </div>
      <div class="contentBx">
        <h2><%= topic.topic %></h2>
        <div class="details">
          <p><%= topic.count %> problems to practice!</p>
        </div>
        <a href="/study/<%= topic.topic %>" class="btn">Start</a>
      </div>
    </div>
  <% }) %>
</div>

<script>
  // Smooth scroll using Lenis
  const lenis = new Lenis({
    duration: 1.2,
    easing: t => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    smooth: true
  });

  function raf(time) {
    lenis.raf(time);
    requestAnimationFrame(raf);
  }

  requestAnimationFrame(raf);

  // Reveal cards when in viewport
  const cards = document.querySelectorAll('.card');
  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('in-view');
      }
    });
  }, { threshold: 0.1 });

  cards.forEach(card => observer.observe(card));
</script>

</body>
</html>
