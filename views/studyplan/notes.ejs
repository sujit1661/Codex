<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>DSA Notes | CodeX</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <style>
    :root {
      --primary: #e6edf3;
      --bg-dark: #000;
      --bg-secondary: #121212;
      --border: #2a2a2a;
      --hover: #1b1b1b;
      --accent: #2ea043;
    }

    * {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      padding: 0;
      height: 100%;
      background-color: var(--bg-dark);
      color: var(--primary);
      font-family: "Segoe UI", Tahoma, sans-serif;
      overflow: hidden; /* Remove this line to allow inner scrolls */
    }

    body {
      display: flex;
      flex-direction: column;
    }

    .navbar {
      background-color: var(--bg-secondary);
      border-bottom: 1px solid var(--border);
      height: 60px;
    }

    .navbar-brand {
      color: var(--primary);
      font-weight: bold;
      font-size: 1.4rem;
    }

    .layout {
      display: flex;
      flex-grow: 1;
      height: calc(100vh - 60px);
      overflow: hidden;
    }

    .sidebar {
      width: 220px;
      background-color: var(--bg-secondary);
      border-right: 1px solid var(--border);
      overflow-y: auto;
      padding-top: 25px;
      flex-shrink: 0;
    }

    .sidebar h5 {
      padding: 10px 20px;
      border-bottom: 1px solid var(--border);
    }

    .sidebar ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .sidebar ul li a {
      display: block;
      padding: 12px 20px;
      color: var(--primary);
      text-decoration: none;
    }

    .sidebar ul li a:hover,
    .sidebar ul li a.active {
      background-color: var(--hover);
    }

    .main-content {
      flex-grow: 1;
      overflow-y: auto;
      padding: 20px 25px;
      height: 100%;
      -ms-overflow-style: none;
      scrollbar-width: none;
    }

    .main-content::-webkit-scrollbar {
      display: none;
    }

    .card.note-card {
      background-color: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 12px;
      text-align: center;
      padding: 20px 15px;
      transition: background 0.3s ease;
      height: 220px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .card.note-card:hover {
      background-color: var(--hover);
    }

    .card img {
      width: 50px;
      margin: auto;
      filter: invert(1);
    }

    .note-title {
      font-weight: bold;
      font-size: 16px;
    }

    .note-desc {
      font-size: 13px;
      color: #aaa;
    }

    .download-btn {
      background-color: var(--accent);
      color: white;
      border-radius: 50%;
      padding: 10px 12px;
      font-size: 16px;
      display: inline-block;
      border: none;
    }

    .download-btn:hover {
      background-color: #238636;
    }

    footer {
      text-align: center;
      padding: 10px;
      font-size: 13px;
      color: #777;
      background-color: var(--bg-secondary);
      border-top: 1px solid var(--border);
    }

    @media (max-width: 768px) {
      .layout {
        flex-direction: column;
      }

      .sidebar {
        width: 100%;
        height: auto;
        border-right: none;
        border-bottom: 1px solid var(--border);
      }

      .main-content {
        padding: 15px;
      }
    }
  </style>
</head>
<body>
  <nav class="navbar px-4 d-flex align-items-center">
    <a class="navbar-brand" href="/">CodeX</a>
  </nav>

  <div class="layout">
    <aside class="sidebar">
      <h5>Navigation</h5>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/start-dsa"> DSA Roadmap</a></li>
        <li><a href="/quizzes">Quizzes</a></li>
        <li><a href="/problems"> Problems</a></li>
        <li><a href="/notes" class="active"> Notes</a></li>
      </ul>
    </aside>

    <main class="main-content">
      <div class="container-fluid">
        <div class="row row-cols-1 row-cols-md-3 g-4">
          <% const pdfTopics = [
            'Array', 'Strings', 'Sorting', 'Recursion', 'Backtracking', 'OOPS',
            'Stacks', 'Queues', 'Hashing', 'Trees', 'BSt', 'Graphs', 'dp', 'os', 'DBMS'
          ]; %>

          <% pdfTopics.forEach(topic => { %>
            <div class="col">
              <div class="card note-card">
                <img src="https://cdn-icons-png.flaticon.com/512/337/337946.png" alt="PDF" />
                <div class="note-title"><%= topic %> Notes</div>
                <div class="note-desc">Download high-quality notes</div>
                <a class="download-btn mt-2 mx-auto" href="/notes/<%= topic %>.pdf" download>
                  ⬇
                </a>
              </div>
            </div>
          <% }); %>
        </div>
      </div>
    </main>
  </div>

  <footer>
    © <%= new Date().getFullYear() %> CodeX. All rights reserved.
  </footer>
</body>
</html>
