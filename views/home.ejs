<!doctype html>
<html lang="en" class="h-100">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>CodeX</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Mono:wght@300&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/@studio-freight/lenis@1.0.26/bundled/lenis.min.js"></script>

    <style>
    html {
      scroll-behavior: auto;
      will-change: transform;
      transform: translateZ(0);
    }

      html, body {
        height: 100%;
        margin: 0;
        color: #c9d1d9;
        font-family: system-ui, sans-serif;
        background-color: #000;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      .cover-container {
        width: 100%;
        max-width: 1000px;
        margin: auto;
      }

      .nav-link {
        color: #c9d1d9;
      }

      .nav-link.active,
      .nav-link:hover {
        color: #ffffff;
        text-decoration: none;
      }

      .btn-codex {
        background-color: #238636;
        color: white;
        border: none;
      }

      .btn-codex:hover {
        background-color: #2ea043;
      }

      .quote-line {
        font-size: 1.5rem;
        font-weight: 300;
        font-family: 'Roboto Mono', monospace;
        color: rgba(255, 255, 255, 0.7);
        margin-top: 3rem;
        text-align: center;
        min-height: 2.5rem;
      }

      .dud {
        color: #333;
      }


      .btn-glass {
        font-size: 16px;
        padding: 12px 21px;
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.15);
        background: linear-gradient(to right, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02));
        color: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        box-shadow: inset 0 0 10px rgba(255, 255, 255, 0.05), 0 0 10px rgba(0, 0, 0, 0.1);
        transition: all 0.3s ease;
        cursor: pointer;
        text-decoration:none;
      }

      .btn-glass:hover {
        box-shadow: 0 0 12px rgba(255, 255, 255, 0.2), inset 0 0 12px rgba(255, 255, 255, 0.08);
        color: white;
      }

      .btn-glass:active {
        transform: scale(0.98);
      }
    </style>
  </head>
  <body class="d-flex h-100 text-center">
    <div class="cover-container d-flex w-100 h-100 p-3 mx-auto flex-column">
      <header class="mb-auto">
        <div>
          <h3 class="float-md-start mb-0">CodeX</h3>
          <nav class="nav nav-masthead justify-content-center float-md-end">
            <a class="nav-link active" href="/">Home</a>
            <a class="nav-link" href="/problems">Problems</a>
            <a class="nav-link" href="/start-dsa">DSA Roadmap</a>
            <a class="nav-link" href="/quizzes">Quizzes</a>
            <a class="nav-link" href="/todo">Todo-List</a>
          </nav>
        </div>
      </header>

      <main class="px-3 my-auto">
        <h1>Master DSA with CodeX</h1>
        <p class="lead">Solve coding challenges, take part in contests, and track your progress.
          Sharpen your DSA, prepare for interviews, and join a community of passionate developers.</p>
       <div class="d-flex flex-column flex-md-row justify-content-center align-items-center gap-3 mt-4">
          <a href="/auth" class="btn btn-lg btn-codex fw-bold px-3">Get Started</a>
          <a href="/ai" class="btn-glass">CodeX Assistant</a>
        </div>

      </main>

      <div class="quote-line mb-4" id="quote"></div>

      <footer class="mt-auto text-white-50">
        <p>© 2025 CodeX. Built with <em>Sujit</em></p>
      </footer>
    </div>

    <script>
      const lenis = new Lenis({
        duration: 1.2,
        easing: t => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smooth: true
      });

      function raf(time) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }

      requestAnimationFrame(raf);


      class TextScramble {
        constructor(el) {
          this.el = el;
          this.chars = '!<>-_\\/[]{}—=+*^?#________';
          this.update = this.update.bind(this);
        }

        setText(newText) {
          const oldText = this.el.innerText;
          const length = Math.max(oldText.length, newText.length);
          const promise = new Promise(resolve => this.resolve = resolve);
          this.queue = [];

          for (let i = 0; i < length; i++) {
            const from = oldText[i] || '';
            const to = newText[i] || '';
            const start = Math.floor(Math.random() * 40);
            const end = start + Math.floor(Math.random() * 40);
            this.queue.push({ from, to, start, end });
          }

          cancelAnimationFrame(this.frameRequest);
          this.frame = 0;
          this.update();
          return promise;
        }

        update() {
          let output = '';
          let complete = 0;

          for (let i = 0, n = this.queue.length; i < n; i++) {
            let { from, to, start, end, char } = this.queue[i];
            if (this.frame >= end) {
              complete++;
              output += to;
            } else if (this.frame >= start) {
              if (!char || Math.random() < 0.28) {
                char = this.randomChar();
                this.queue[i].char = char;
              }
              output += `<span class="dud">${char}</span>`;
            } else {
              output += from;
            }
          }

          this.el.innerHTML = output;

          if (complete === this.queue.length) {
            this.resolve();
          } else {
            this.frameRequest = requestAnimationFrame(this.update);
            this.frame++;
          }
        }

        randomChar() {
          return this.chars[Math.floor(Math.random() * this.chars.length)];
        }
      }

      const quotes = [
        'Create. Code. Compile. Welcome to CodeX.',
        'With great power comes great responsibility — and great logic.',
        'CodeX isn’t just a platform — it’s a proving ground.',
        'Transform code into craft with CodeX.',
        'You don’t just learn here, you evolve — CodeX.',
        'Compile dreams. Execute clarity. CodeX.',
        'More than syntax — CodeX builds thinkers.',
        'Power comes in response to a need, not a desire.',
        'Fear is not evil. It tells you what your weakness is.',
        'A lesson without pain is meaningless.',
        'A person grows up when he’s able to overcome hardships.',
        'The world isn’t perfect. But it’s there for us, trying the best it can.',
        'Push through the pain. Giving up hurts more.',
        'Hard work is worthless for those that don’t believe in themselves.'
      ];

      const el = document.getElementById('quote');
      const fx = new TextScramble(el);

      let counter = 0;
      const next = () => {
        fx.setText(quotes[counter]).then(() => {
          setTimeout(next, 2000);
        });
        counter = (counter + 1) % quotes.length;
      };

      next();
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
