<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>DSA Roadmap | CodeX</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600&display=swap">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">


  <style>
    :root {
      --clr-blue: #1890ff;
      --clr-green: #01c3a8;
      --clr-orange: #ffb741;
      --clr-red: #a63d2a;
    }


    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      min-height: 100vh;
    background-color: #000000;
      font-family: "Nunito", sans-serif;
      display: grid;
      place-items: center;
      overflow-x: hidden;
    }

    section {
      width: 100%;
      max-width: 70em;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 3rem;
      padding: 5em 1em;
    }

    .card {
      position: relative;
      width: 18rem;
      min-height: 20rem;
      border-radius: 2.25rem;
      box-shadow: 0 1rem 2rem rgba(0, 0, 0, 0.6);
      display: grid;
      place-items: center;
      text-align: center;
    }

    .card::before {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: 2.25rem;
      border: 2.5px solid transparent;
      mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
      mask-composite: exclude;
      -webkit-mask-composite: destination-out;
      z-index: -1;
    }

    .card-header,
    .card-footer {
      width: 100%;
      padding: 1em 1.5em;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .card-header .date {
      color: #ddd;
    }

    .card-body {
      padding: 1.5em;
    }

    .card-body h3 {
      font-size: 1.5rem;
      color: #fff;
      margin-bottom: 0.4em;
    }

    .card-body p {
      color: #bbb;
      font-size: 1rem;
      margin-bottom: 1rem;
    }

    .progress span {
      display: block;
      color: #fff;
      margin-bottom: 0.3rem;
      font-weight: 600;
    }

    .progress-bar {
      background: #333;
      height: 6px;
      border-radius: 10px;
      position: relative;
      margin-bottom: 0.3rem;
    }

    .progress-bar::after {
      content: "";
      position: absolute;
      height: 100%;
      top: 0;
      left: 0;
      border-radius: 10px;
      width: 0%;
    }

    .btn-countdown {
      background: #222127;
      color: #fff;
      padding: 0.5rem 1.25rem;
      border-radius: 2em;
      font-size: 0.9rem;
      text-decoration: none;
      transition: 0.3s;
    }

    .btn-countdown:hover {
      filter: brightness(1.1);
    }

    .green { background: radial-gradient(ellipse at top right, #107667ed 0%, #151419 47%, #151419 100%); }
    .green::before { background: linear-gradient(45deg, #232228, #232228, #01c3a8) border-box; }
    .green .progress-bar::after { background: var(--clr-green); }
    .green .btn-countdown:hover { background: var(--clr-green); }

    .orange { background: radial-gradient(ellipse at top right, #ffb74194 0%, #151419 47%, #151419 100%); }
    .orange::before { background: linear-gradient(45deg, #232228, #232228, #ffb741) border-box; }
    .orange .progress-bar::after { background: var(--clr-orange); }
    .orange .btn-countdown:hover { background: var(--clr-orange); }

    .red { background: radial-gradient(ellipse at top right, #a63d2a82 0%, #151419 47%, #151419 100%); }
    .red::before { background: linear-gradient(45deg, #232228, #232228, #a63d2a) border-box; }
    .red .progress-bar::after { background: var(--clr-red); }
    .red .btn-countdown:hover { background: var(--clr-red); }

    .blue { background: radial-gradient(ellipse at top right, #00458f8f 0%, #151419 45%, #151419 100%); }
    .blue::before { background: linear-gradient(45deg, #232228, #232228, #1890ff) border-box; }
    .blue .progress-bar::after { background: var(--clr-blue); }
    .blue .btn-countdown:hover { background: var(--clr-blue); }


    .card {
      position: relative;
      width: 18rem;
      min-height: 20rem;
      border-radius: 2.25rem;
      box-shadow: 0 1rem 2rem rgba(0, 0, 0, 0.6);
      display: grid;
      place-items: center;
      text-align: center;
      transition: transform 0.4s ease, box-shadow 0.5s ease, border 0.5s ease;
      border: 1px solid transparent;
      overflow: hidden;
      z-index: 0;
    }

    .card::before {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: 2.25rem;
      background: linear-gradient(130deg, #5fdfff, #a9f1ff);
      opacity: 0;
      filter: blur(12px);
      transition: opacity 0.5s ease;
      z-index: -1;
    }

    .card:hover {
      border: 1px solid #5fdfff;
      box-shadow: 0 0 20px rgba(95, 223, 255, 0.3), 0 8px 25px rgba(0, 0, 0, 0.5);
      transform: scale(1.02);
    }

    .card:hover::before {
      opacity: 0.6;
    }




  </style>
</head>
