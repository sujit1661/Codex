<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CodeX Quiz</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>

    html, body {
      height: 100%;
      margin: 0;
      background-color: #000000;
      font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      color: #e6edf3;
    }

    .navbar {
      background-color: #0a0a0a;
      padding: 12px 24px;
      border-bottom: 1px solid #333;
    }

    .navbar-brand {
      color: #58a6ff;
      font-weight: bold;
      font-size: 1.4rem;
      text-decoration: none;
    }

    .navbar-nav .nav-link {
      color: #e6edf3;
      margin-left: 15px;
      transition: color 0.2s ease;
      text-decoration: none;
    }

    .navbar-nav .nav-link:hover,
    .navbar-nav .nav-link.active {
      color: #58a6ff;
    }

    .quiz-wrapper {
      max-width: 800px;
      margin: 40px auto;
      background-color: #111;
      padding: 30px;
      border-radius: 12px;
      box-shadow: 0 0 20px rgba(255,255,255,0.05);
      border: 1px solid #222;
    }

    .question-box {
      background-color: #141414;
      padding: 20px;
      border-radius: 8px;
      border: 1px solid #222;
      margin-bottom: 25px;
    }

    .option {
      border: 2px solid #333;
      background-color: #1a1a1a;
      border-radius: 6px;
      padding: 10px 15px;
      margin-bottom: 10px;
      transition: background-color 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
      display: flex;
      align-items: center;
      color: #e6edf3;
      cursor: pointer;
    }

    .option input {
      margin-right: 10px;
    }

    .option:hover {
      background-color: #2ea043;
      color: white;
      border-color: #2ea043;
    }

    .option.selected {
      border: 2px solid #58a6ff !important;
      box-shadow: 0 0 8px rgba(88, 166, 255, 0.6);
    }

    .correct {
      background-color: #1f6f3d !important;
      color: #adffb0 !important;
      border: 2px solid #2ea043 !important;
    }

    .incorrect {
      background-color: #8c1c13 !important;
      color: #ffd6d4 !important;
      border: 2px solid #842029 !important;
    }

    .btn-success {
      background-color: #2ea043;
      border-color: #2ea043;
    }

    .btn-success:hover {
      background-color: #238636;
      border-color: #1f6f3d;
    }

    .highlight-user-answer {
      background-color: rgba(46, 160, 67, 0.2);
      color: #58d68d;
      border-radius: 4px;
      padding: 6px 12px;
      display: inline-block;
      margin-top: 8px;
      font-size: 0.9rem;
      border: 1px solid #2ea043;
    }

    footer {
      text-align: center;
      padding: 20px;
      color: #888;
      background-color: #0a0a0a;
      border-top: 1px solid #222;
      font-size: 14px;
    }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">CodeX</a>
      <div class="navbar-nav">
        <a class="nav-link" href="/">Home</a>
        <a class="nav-link" href="/start-dsa">DSA Roadmap</a>
        <a class="nav-link active" href="/quizzes"> Quizzes</a>
        <a class="nav-link" href="/problems"> Problems</a>
      </div>
    </div>
  </nav>

  <div class="container">
    <div class="quiz-wrapper">
      <h2 class="mb-4 text-info text-center"> Quiz on <%= topic.replace('-', ' ') %></h2>

      <% if (score !== null) { %>
        <div class="alert alert-success text-center">
          ✅ You scored <strong><%= score %></strong> out of <%= questions.length %>
        </div>
      <% } %>

      <form method="POST" action="/quiz/<%= topic %>/submit">
        <% questions.forEach((q, idx) => { %>
          <div class="question-box" data-qid="<%= q.id %>">
            <p class="fw-semibold">Q<%= idx + 1 %>: <%= q.question %></p>

            <% ['A', 'B', 'C', 'D'].forEach(opt => {
              const value = q[`option_${opt.toLowerCase()}`];
              const selected = q.userAnswer === opt;
              const isCorrect = opt === q.correct_option;
              const isWrong = selected && !isCorrect;
            %>
              <label class="option
                <%= selected ? 'selected' : '' %>
                <%= score !== null && isCorrect ? ' correct' : '' %>
                <%= score !== null && isWrong ? ' incorrect' : '' %>" data-opt="<%= opt %>">

                <input type="radio" name="q<%= q.id %>" value="<%= opt %>" <%= selected ? 'checked' : '' %> <%= score === null ? '' : 'disabled' %> />
                <%= opt %>: <%= value %>
              </label>
            <% }) %>

            <% if (score !== null && q.userAnswer) { %>
              <div class="highlight-user-answer">
                You selected: <strong><%= q.userAnswer %></strong>
              </div>
            <% } %>
          </div>
        <% }) %>

        <div class="text-center mt-4">
          <% if (score === null) { %>
            <button type="submit" class="btn btn-success btn-lg">✅ Submit Quiz</button>
          <% } %>
        </div>
      </form>
    </div>
  </div>

  <footer>
    Copyright © <%= new Date().getFullYear() %> CodeX. All rights reserved.
  </footer>

  <script>

    document.querySelector("form")?.addEventListener("submit", function (e) {
      const questions = <%= JSON.stringify(questions.map(q => q.id)) %>;
      let allAnswered = true;

      for (const qid of questions) {
        if (!document.querySelector(`input[name="q${qid}"]:checked`)) {
          allAnswered = false;
          break;
        }
      }

      if (!allAnswered) {
        e.preventDefault();
        alert("❗ Please attempt all questions before submitting.");
      }
    });

    document.querySelectorAll(".question-box").forEach(box => {
      box.addEventListener("change", () => {
        const options = box.querySelectorAll(".option");
        options.forEach(opt => opt.classList.remove("selected"));

        const checked = box.querySelector("input[type='radio']:checked");
        if (checked) {
          checked.closest(".option").classList.add("selected");
        }
      });
    });
  </script>
</body>
</html>
